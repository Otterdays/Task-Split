<Window x:Class="TaskSplit.Views.TaskbarOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task-Split Overlay"
        Background="#FF252526"
        AllowsTransparency="False"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        MinWidth="160"
        MinHeight="180"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TitleBarBorder"
                Grid.Row="0"
                Background="#FF1A1A1C"
                BorderBrush="#33FFFFFF"
                BorderThickness="0,0,0,1"
                Padding="8,3">
            <Border.ToolTip>
                <ToolTip Content="Drag to move · Pull sides or bottom edge to resize"
                         FontFamily="Segoe UI"
                         FontSize="11"
                         Background="#FF2A2A2E"
                         Foreground="White"
                         BorderBrush="#55FFFFFF"
                         BorderThickness="1"
                         Padding="8,4,8,4" />
            </Border.ToolTip>
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <TextBlock Text="Task"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#E6FFFFFF"
                               VerticalAlignment="Center" />
                    <TextBlock Text="-Split"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#FF5B8CFF"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock x:Name="HintText"
                           Text="drag title · resize sides"
                           FontFamily="Segoe UI"
                           FontSize="8"
                           Foreground="#55FFFFFF"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           IsHitTestVisible="False" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8,6,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Canvas x:Name="OverlayCanvas"
                    Grid.RowSpan="2"
                    Panel.ZIndex="0"
                    IsHitTestVisible="False" />

            <Button x:Name="AddAppButton"
                    Grid.Row="0"
                    Panel.ZIndex="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Padding="8,4"
                    Cursor="Hand"
                    Background="#FF2A2A2E"
                    BorderBrush="#FF5B8CFF"
                    BorderThickness="1"
                    Click="AddAppButton_Click">
                <Button.ToolTip>
                    <ToolTip Content="Search installed apps and add one to a group"
                             FontFamily="Segoe UI"
                             FontSize="11"
                             Background="#FF2A2A2E"
                             Foreground="White"
                             BorderBrush="#55FFFFFF"
                             BorderThickness="1"
                             Padding="8,4,8,4" />
                </Button.ToolTip>
                <StackPanel Orientation="Horizontal">
                    <Border Width="14"
                            Height="14"
                            CornerRadius="7"
                            Background="#FF5B8CFF"
                            VerticalAlignment="Center">
                        <TextBlock Text="+"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-1,0,0" />
                    </Border>
                    <TextBlock Text="Add App"
                               Margin="6,0,0,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <ScrollViewer Grid.Row="1"
                          Panel.ZIndex="1"
                          Margin="0,8,0,0"
                          Focusable="True"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="GroupsPanel" />
            </ScrollViewer>
        </Grid>

        <Border Grid.RowSpan="2"
                BorderBrush="White"
                BorderThickness="2"
                Background="Transparent"
                IsHitTestVisible="False" />

        <!-- Resize grip hints (visual only — hit-testing stays in WndProc) -->
        <Grid x:Name="ResizeGripLayer"
              Grid.RowSpan="2"
              Panel.ZIndex="3"
              IsHitTestVisible="False">
            <Border x:Name="LeftGrip"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#005B8CFF" Offset="0" />
                        <GradientStop Color="#885B8CFF" Offset="0.55" />
                        <GradientStop Color="#FF5B8CFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Line x:Name="LeftGripDash"
                      Y1="0"
                      Stroke="#FFFFFFFF"
                      StrokeThickness="2"
                      StrokeDashArray="4 3"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Opacity="0.85" />
            </Border>

            <Border x:Name="RightGrip"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,0.5" EndPoint="0,0.5">
                        <GradientStop Color="#005B8CFF" Offset="0" />
                        <GradientStop Color="#885B8CFF" Offset="0.55" />
                        <GradientStop Color="#FF5B8CFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Line x:Name="RightGripDash"
                      Y1="0"
                      Stroke="#FFFFFFFF"
                      StrokeThickness="2"
                      StrokeDashArray="4 3"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Opacity="0.85" />
            </Border>

            <Border x:Name="BottomGrip"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
                        <GradientStop Color="#005B8CFF" Offset="0" />
                        <GradientStop Color="#885B8CFF" Offset="0.55" />
                        <GradientStop Color="#FF5B8CFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Line x:Name="BottomGripDash"
                      X1="0"
                      Y1="0"
                      Stroke="#FFFFFFFF"
                      StrokeThickness="2"
                      StrokeDashArray="4 3"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Opacity="0.85" />
            </Border>
        </Grid>
    </Grid>
</Window>
