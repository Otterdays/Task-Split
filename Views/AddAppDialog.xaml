<Window x:Class="TaskSplit.Views.AddAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task-Split — Add App"
        Width="480"
        Height="420"
        MinWidth="400"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="#FF252526"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Add application to group"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Group"
                       Foreground="#CCFFFFFF"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <ComboBox x:Name="GroupCombo"
                      Grid.Column="1"
                      DisplayMemberPath="Name"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      Background="White"
                      Foreground="Black"
                      BorderBrush="#FF5B8CFF"
                      BorderThickness="1"
                      Padding="8,6">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFD6E4FF" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />
                </ComboBox.Resources>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="Background" Value="White" />
                        <Setter Property="FontFamily" Value="Segoe UI" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Padding" Value="8,4" />
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="Background" Value="#FFD6E4FF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="Background" Value="#FFB8D4FF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     FontFamily="Segoe UI"
                     FontSize="12"
                     Padding="8,6"
                     Background="#FF1E1E1E"
                     Foreground="White"
                     BorderBrush="#445B8CFF"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Search by app name or scan filesystem for exe files" />
            <Button Grid.Column="1"
                    Content="Browse…"
                    Margin="8,0,0,0"
                    Padding="12,6"
                    Click="BrowseButton_Click"
                    Background="#FF2D2D30"
                    Foreground="White"
                    BorderBrush="#FF5B8CFF" />
        </Grid>

        <ListBox x:Name="ResultsList"
                 Grid.Row="3"
                 FontFamily="Segoe UI"
                 FontSize="12"
                 Background="#FF1A1A1C"
                 BorderBrush="#33FFFFFF"
                 Foreground="White"
                 Margin="0,0,0,12"
                 SelectionChanged="ResultsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,2">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Text="{Binding ExePath}"
                                   FontSize="10"
                                   Foreground="#88FFFFFF"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="9" Foreground="#665B8CFF">
                            <Run Text="{Binding ProcessName, Mode=OneWay}" />
                            <Run Text=" · " />
                            <Run Text="{Binding Source, Mode=OneWay}" />
                            <Run Text="{Binding AddedAtLabel, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#88FFFFFF"
                       FontSize="10"
                       Margin="0,0,12,0" />
            <Button Content="Cancel"
                    Padding="14,6"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    Background="#FF2D2D30"
                    Foreground="White"
                    BorderBrush="#55FFFFFF" />
            <Button Content="Add App"
                    Padding="14,6"
                    Click="AddButton_Click"
                    IsEnabled="False"
                    x:Name="AddButton"
                    Background="#FF5B8CFF"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderBrush="#FF5B8CFF" />
        </StackPanel>
    </Grid>
</Window>
